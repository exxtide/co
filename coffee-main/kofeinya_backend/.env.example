# Django Settings
DJANGO_ENV=production
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-backend-domain.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-backend-domain.onrender.com,https://your-frontend-domain.onrender.com
FRONTEND_URL=https://your-frontend-domain.onrender.com
DJANGO_BEHIND_PROXY=true

# Admin User (автоматически создается при деплое)
DJANGO_ADMIN_EMAIL=admin@example.com
DJANGO_ADMIN_PASSWORD=your-secure-password-here
DJANGO_ADMIN_NAME=Admin

# Database (автоматически предоставляется Render)
DATABASE_URL=postgresql://user:password@host:port/database

# Email (опционально)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# DaData (опционально)
DADATA_TOKEN=your-dadata-token
