############################################
# Django (production hardening template)
############################################

# production | development
DJANGO_ENV=production

# MUST be long random string in prod (no default!)
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# In production MUST be "false"
DJANGO_DEBUG=false

# Comma-separated hosts, e.g. "example.com,www.example.com"
DJANGO_ALLOWED_HOSTS=example.com

# Frontend origin (used for email links and allowed origins)
FRONTEND_URL=https://example.com

# Comma-separated origins, e.g. "https://example.com,https://www.example.com"
CORS_ALLOWED_ORIGINS=https://example.com

# CSRF trusted origins (scheme required), comma-separated
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com

# If behind reverse proxy (nginx, traefik, cloudflare), enable:
DJANGO_BEHIND_PROXY=true

# Force https redirect (recommended in prod)
SECURE_SSL_REDIRECT=true

# HSTS (recommended in prod; set to 0 only if you know why)
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# DRF throttling (tune as needed)
DRF_THROTTLE_ANON=120/minute
DRF_THROTTLE_USER=600/minute

# Upload limits (bytes)
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Cross-Origin-Resource-Policy (advanced; off by default)
#ENABLE_CORP_HEADER=true
#CROSS_ORIGIN_RESOURCE_POLICY=same-origin

# DaData (optional)
DADATA_TOKEN=

# Email (optional; console by default in dev)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com
